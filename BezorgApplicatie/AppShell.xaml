<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BezorgApplicatie.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BezorgApplicatie.Views"
    Title="BezorgApplicatie">

    <TabBar>
        <ShellContent
            Icon="agenda.png"
            Title="Dienst"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
        <ShellContent
            Icon="map.png"
            Title="Kaart"
            ContentTemplate="{DataTemplate views:NewPage1}"
            Route="NewPage1" />
        <ShellContent
            Icon="orders.png"
            Title="Orders"
            ContentTemplate="{DataTemplate views:AllStopsPage}"
            Route="NewPage1" />
        <ShellContent
            Icon="warning.png"
            Title="Schade"
            ContentTemplate="{DataTemplate views:NewPage1}"
            Route="NewPage1" />
    </TabBar>

</Shell>
