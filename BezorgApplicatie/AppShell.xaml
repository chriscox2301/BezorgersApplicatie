<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    x:Class="BezorgApplicatie.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BezorgApplicatie.Views"
    xmlns:local="clr-namespace:BezorgApplicatie"
    Title="BezorgApplicatie">

    <TabBar>
        <ShellContent
            Icon="agenda.png"
            Title="Dienst"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
        <ShellContent
            Icon="map.png"
            Title="Kaart"
            ContentTemplate="{DataTemplate views:RouteMap}"
            Route="RouteMap" />
        <ShellContent
            Icon="barcodescanner.png"
            Title="Scannen"
            ContentTemplate="{DataTemplate views:PakkettenInscannen}"
            Route="PakkettenInscannen" />
        <ShellContent
            Icon="orders.png"
            Title="Orders"
            ContentTemplate="{DataTemplate views:AllStopsPage}"
            Route="AllStopsPage" />
        <ShellContent
            Icon="warning.png"
            Title="Schade"
            ContentTemplate="{DataTemplate views:VehicleDamagePage}"
            Route="NewPage1" />
    </TabBar>

</Shell>
