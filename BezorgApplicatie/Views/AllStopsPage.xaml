<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.AllStopsPage"
             Title="AllStopsPage">
    <VerticalStackLayout>
        <SearchBar x:Name="Zoekbalk" Placeholder="Zoeken..." TextChanged="ZoektermIngevuld"/>

        <!-- "Tabs" -->
        <HorizontalStackLayout>
            <Button Text="Te Doen" Clicked="ToDoClicked"/>
            <Button Text="Afgerond" Clicked="CompletedClicked"/>
            <Button Text="Anders" Clicked="DifferentClicked"/>
        </HorizontalStackLayout>

        
        <CollectionView x:Name="StopsList" SelectionMode="Single" SelectionChanged="StopSelected">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    
                    <Border StrokeThickness="1" Stroke="Black">
                        <VerticalStackLayout>
                            <Label Text="{Binding Id, StringFormat='#{0}'}"/>
                            <Label Text="{Binding Address}" />
                            <Label Text="{Binding Packages.Count}" />
                        </VerticalStackLayout>
                    </Border>
                    
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
        </CollectionView>
        
    </VerticalStackLayout>
    
</ContentPage>