<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.AllStopsPage"
             Title="AllStopsPage">
    <VerticalStackLayout BackgroundColor="WhiteSmoke">
        <SearchBar Placeholder="Zoeken..."></SearchBar>

        <CollectionView ItemsSource="{Binding Stops}" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Stroke="Black">
                        <VerticalStackLayout>
                            <Label Text="{Binding Address}" />
                            <Label Text="{Binding Packages.Count}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>