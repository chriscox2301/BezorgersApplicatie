<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.PakkettenInscannen"
             Title="PakkettenInscannen">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <BoxView 
                 Color="CornflowerBlue"
                 CornerRadius="10"
                 WidthRequest="357"
                 HeightRequest="160"
                 VerticalOptions="Center"
                 HorizontalOptions="Center"
        />
        <FlexLayout AlignItems="Center"
                    AlignContent="Stretch">
            <Button
                WidthRequest="120"
                HeightRequest="120"
                BackgroundColor="Blue"
                BorderColor="White"
                BorderWidth="3"
                CornerRadius="65"
                Clicked="TakePhotoCommand"
                ImageSource="barcodescanicon.png"
            />

        </FlexLayout>
        <BoxView
                BackgroundColor="Beige"
                WidthRequest="335"
            HeightRequest="300"
            Margin="35"
            HorizontalOptions="Fill"
                
                
            />

        <ListView>
            <ListView.ItemTemplate>
                <TextCell
                    Text="test">
                </TextCell>
            </ListView.ItemTemplate>
        </ListView>


    </VerticalStackLayout>

</ContentPage>