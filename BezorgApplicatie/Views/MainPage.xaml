<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Eerstvolgende dienst"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Frame Padding="20"
                   CornerRadius="15"
                   HasShadow="True"
                   BackgroundColor="White"
                   BorderColor="LightGray">

                <VerticalStackLayout Spacing="12">

                    <Label x:Name="lblDate"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />

                    <BoxView HeightRequest="1"
                             Color="LightGray" />

                    <Label x:Name="lblStart"
                           FontSize="16"
                           TextColor="Black" />

                    <Label x:Name="lblEnd"
                           FontSize="16"
                           TextColor="Black" />

                    <Label x:Name="lblWarehouse"
                           FontSize="16"
                           TextColor="Black" />
                    
                    <Label x:Name="lblOrders"
                           FontSize="16"
                           TextColor="Black" />

                    <Label x:Name="lblVehicle"
                           FontSize="16"
                           TextColor="Black" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>