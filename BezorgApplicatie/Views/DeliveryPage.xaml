<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BezorgApplicatie.Models"
             xmlns:local="clr-namespace:BezorgApplicatie.Views"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="BezorgApplicatie.Views.DeliveryPage"
             x:DataType="local:DeliveryPage"
             Title="DeliveryPage">

    <Grid 
        RowDefinitions=".07*, .25*, .05*, .05*, .30*, .10*"
        ColumnDefinitions=".50*, .50*">

        <Label Grid.Row="0"
               Grid.ColumnSpan="2"
               Text="Bezorgen"
               FontAttributes="Bold"
               FontSize="24"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="2">
            <zxing:CameraBarcodeReaderView
                x:Name="barcodeReader"
                BarcodesDetected="barcodeReader_BarcodesDetected"/>
        </Border>

        <Label Grid.Row="2"
               Grid.ColumnSpan="2"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               Text="{Binding Order.Address}"
               />

        <Label Grid.Row="3"
               Grid.Column="1"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               x:Name="FeedbackLabel"
               TextColor="Red"
               />

        <Label Grid.Row="3"
               Grid.Column="0"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               Text="{Binding Order.Location, StringFormat='Location: {0}'}"
            />

        <CollectionView Grid.ColumnSpan="2" Grid.Row="4" ItemsSource="{Binding Packages}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout 
                        Orientation="Vertical"
                        ItemSpacing="5"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Package">
                    <Frame HeightRequest="80" 
                               BorderColor="Black"
                               VerticalOptions="Start"
                               HorizontalOptions="Fill"
                               CornerRadius="5"
                               Padding="8">
                        <Grid ColumnDefinitions=".15*, .40*, .20*, .15*">
                            <Label HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="0" 
                                       Text="{Binding Number}" 
                                       TextColor="Black"/>
                            <Label HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="1" 
                                       Text="{Binding Barcode}" 
                                       TextColor="Black"/>
                            <Button Grid.Column="2"
                                        Clicked="OnProblemClicked"
                                        WidthRequest="65"
                                        BackgroundColor="Red"/>
                            <Label HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="3" 
                                       Text="{Binding Status}" 
                                       TextColor="Black"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="5"
                Grid.Column="0"
                HeightRequest="60"
                WidthRequest="150"
                BackgroundColor="Blue"
                Text="Bezorgd"
                TextColor="White"
                FontAttributes="Bold"
                />

        <Button Grid.Row="5"
                Grid.Column="1"
                HeightRequest="60"
                WidthRequest="150"
                BackgroundColor="Orange"
                Text="Anders"
                FontAttributes="Bold"
TextColor="White"
                />

    </Grid>
</ContentPage>