<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BezorgApplicatie.Models"
             xmlns:local="clr-namespace:BezorgApplicatie.Views"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="BezorgApplicatie.Views.DeliveryPage"
             x:DataType="local:DeliveryPage"
             Title="DeliveryPage">

    <Grid 
        RowDefinitions=".07*, .25*, .05*, .05*, .30*, .10*"
        ColumnDefinitions=".50*, .50*">

        <Label Grid.Row="0"
               Grid.ColumnSpan="2"
               Text="Bezorgen"
               FontAttributes="Bold"
               FontSize="24"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="2">
            <zxing:CameraBarcodeReaderView
                x:Name="barcodeReader"
                BarcodesDetected="barcodeReader_BarcodesDetected"/>
        </Border>

        <Label Grid.Row="2"
               Grid.ColumnSpan="2"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               Text="{Binding Order.Address}"
               />

        <Label Grid.Row="3"
               Grid.Column="1"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               x:Name="FeedbackLabel"
               TextColor="Red"
               />

        <Label Grid.Row="3"
               Grid.Column="0"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               Text="{Binding Order.Location, StringFormat='Location: {0}'}"
            />

        <CollectionView Grid.ColumnSpan="2" Grid.Row="4" ItemsSource="{Binding Packages}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout 
                        Orientation="Vertical"
                        ItemSpacing="5"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Package">
                    <Frame     x:Name="PackageFrame"
                               HeightRequest="80" 
                               BorderColor="Black"
                               VerticalOptions="Start"
                               HorizontalOptions="Fill"
                               CornerRadius="5"
                               Padding="8">

                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding Status}"
                                         Value="Present">
                                <Setter Property="BackgroundColor" Value="DarkSeaGreen"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding Status}"
                                         Value="Probleem Gemeld">
                                <Setter Property="BackgroundColor" Value="IndianRed"/>
                            </DataTrigger>
                        </Frame.Triggers>
                        
                        <Grid ColumnDefinitions=".07*, .43*, .15*, .20*">
                            <Label     HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="0" 
                                       Text="{Binding Number}" 
                                       TextColor="Black"/>
                            <Label HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="1" 
                                       Text="{Binding Barcode}" 
                                       TextColor="Black"/>
                            <Button     Grid.Column="2"
                                        ImageSource="warning.png"
                                        Clicked="OnProblemClicked"
                                        WidthRequest="65"
                                        BackgroundColor="Goldenrod"/>
                            <Label HorizontalTextAlignment="Center" 
                                       VerticalTextAlignment="Center" 
                                       FontAttributes="Bold"
                                       Grid.Column="3" 
                                       Text="{Binding Status}" 
                                       TextColor="Black"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="5"
                Grid.Column="0"
                x:Name="BezorgdBtn"
                HeightRequest="60"
                WidthRequest="150"
                BackgroundColor="Grey"
                Text="Bezorgd"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="BezorgdBtn_Clicked"
                IsEnabled="False"
                />
        <Border x:Name="AndersBorder"
                BackgroundColor="Grey"
                Grid.Row="5"
                Grid.Column="1"
                HeightRequest="60"
                WidthRequest="150">
            
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5" />
            </Border.StrokeShape>
            
            <Picker 
            x:Name="AndersPicker"
            Title="Anders"
            FontAttributes="Bold"
            TitleColor="White"
            IsEnabled="False"
            SelectedIndexChanged="OnAndersPickerChanged"
            HorizontalTextAlignment="Center"
            VerticalTextAlignment="Center"
            >
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Buren</x:String>
                        <x:String>Pakketpunt</x:String>
                        <x:String>Geweigerd</x:String>
                        <x:String>Anders</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Border>
    </Grid>
</ContentPage>