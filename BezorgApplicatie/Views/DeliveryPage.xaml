<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.DeliveryPage"
             Title="DeliveryPage">
    <ScrollView>
        <VerticalStackLayout>
            <Label Text="{Binding Order.Status}" />
            <CollectionView ItemsSource="{Binding Packages}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding Barcode}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>