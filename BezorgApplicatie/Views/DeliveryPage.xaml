<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BezorgApplicatie.Models"
             xmlns:local="clr-namespace:BezorgApplicatie.Views"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="BezorgApplicatie.Views.DeliveryPage"
             x:DataType="local:DeliveryPage"
             Title="DeliveryPage">

    <Grid 
        RowDefinitions=".07*, .25*, .05*, .05*, .30*, .10*"
        ColumnDefinitions=".50*, .50*">

        <Label Grid.Row="0"
               Grid.ColumnSpan="2"
               Text="Bezorgen"
               FontAttributes="Bold"
               FontSize="24"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="2">
                <zxing:CameraBarcodeReaderView
                x:Name="barcodeReader"
                BarcodesDetected="barcodeReader_BarcodesDetected"/>
        </Border>

        <Label Grid.Row="2"
               Grid.ColumnSpan="2"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               Text="{Binding Order.Address}"
               />

        <Label Grid.Row="3"
               Grid.Column="1"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               />

        <Label Grid.Row="3"
               Grid.Column="0"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               FontAttributes="Bold"
               Text="{Binding Order.Location, StringFormat='Location: {0}'}"
            />
        
        <CollectionView Grid.ColumnSpan="2" Grid.Row="4" ItemsSource="{Binding Packages}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout 
                        Orientation="Vertical"
                        ItemSpacing="5"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Package">
                        <Frame HeightRequest="80" 
                               BorderColor="Black"
                               VerticalOptions="Start"
                               HorizontalOptions="Fill"
                               CornerRadius="5"
                               Padding="8">
                            <StackLayout>
                                <Label Text="{Binding .}" />
                                <Label Text="{Binding Number}"/>
                                <Label Text="{Binding Barcode}"/>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>       