<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApplicatie.Views.StopDetailPage"
             Title="{Binding Id, StringFormat='#{0}'}">
    <VerticalStackLayout Padding="15" Spacing="15">

       
        <Border Stroke="Black" StrokeThickness="1" Padding="10">
            <VerticalStackLayout Spacing="5">
                <Label Text="Adres"
                           FontAttributes="Bold"
                           FontSize="16" />

                <Label Text="{Binding Address}"
                           FontSize="14" />
            </VerticalStackLayout>
        </Border>

        
        <Label Text="Pakketten"
                   FontAttributes="Bold"
                   FontSize="18" />

        <CollectionView ItemsSource="{Binding Packages}"
                            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Stroke="Gray"
                                StrokeThickness="1"
                                Padding="10"
                                Margin="0,5">

                        <Grid ColumnDefinitions="Auto,*">

                            
                            <Label Text="📦"
                                       FontSize="20"
                                       VerticalOptions="Center" />

                            
                            <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">

                                <Label Text="Barcode:"
                                           FontAttributes="Bold"
                                           FontSize="12" />

                                <Label Text="{Binding Barcode}"
                                           FontSize="14" />

                            </VerticalStackLayout>

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
</ContentPage>